APP_NAME="FDE Enterprise Invoice Platform"
APP_ENV=production
APP_DEBUG=false
BACKEND_PORT=8000
FRONTEND_PORT=3000
BACKEND_IMAGE=invoice-platform-backend:replace-with-commit-sha
FRONTEND_IMAGE=invoice-platform-frontend:replace-with-commit-sha
VITE_API_BASE_URL=https://replace-with-production-api.example.com

POSTGRES_DB=invoice_platform
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=replace-with-production-database-password
DATABASE_URL=postgresql+psycopg://invoice_user:replace-with-production-database-password@postgres:5432/invoice_platform
REDIS_URL=redis://redis:6379/0
PROCESSING_QUEUE_NAME=invoice_processing_jobs
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_SLEEP_SECONDS=1
PROCESSING_JOB_MAX_ATTEMPTS=3

OPENAI_API_KEY=replace-with-production-openai-key
OPENAI_EXTRACTION_MODEL=gpt-4.1
OPENAI_INPUT_COST_PER_MILLION_TOKENS=0
OPENAI_OUTPUT_COST_PER_MILLION_TOKENS=0
# Gemini extraction provider (leave key empty to disable this option).
GEMINI_API_KEY=replace-with-production-gemini-key
GEMINI_EXTRACTION_MODEL=gemini-2.5-flash
GEMINI_INPUT_COST_PER_MILLION_TOKENS=0
GEMINI_OUTPUT_COST_PER_MILLION_TOKENS=0

OBJECT_STORAGE_BUCKET=invoice-platform-production
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_LOCAL_PATH=/app/.local-storage
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-production-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-production-secret-key
INVOICE_UPLOAD_MAX_BYTES=10485760
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_REQUESTS=20
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
CORS_ALLOWED_ORIGINS=https://replace-with-production-frontend.example.com
INVOICE_FILE_DOWNLOAD_URL_TTL_SECONDS=300
JWT_SECRET=replace-with-strong-production-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
OTEL_ENABLED=false
OTEL_SERVICE_NAME=invoice-platform-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
RUN_MIGRATIONS_ON_START=false
