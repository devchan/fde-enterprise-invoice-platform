APP_NAME="FDE Enterprise Invoice Platform"
APP_ENV=local
APP_DEBUG=true
BACKEND_PORT=8010
FRONTEND_PORT=3000
POSTGRES_PORT=55432
REDIS_PORT=56380

DATABASE_URL=postgresql+psycopg://invoice_user:invoice_pass@localhost:5432/invoice_platform
REDIS_URL=redis://localhost:6379/0
PROCESSING_QUEUE_NAME=invoice_processing_jobs
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_SLEEP_SECONDS=1
PROCESSING_JOB_MAX_ATTEMPTS=3

OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-4.1
OPENAI_INPUT_COST_PER_MILLION_TOKENS=0
OPENAI_OUTPUT_COST_PER_MILLION_TOKENS=0
# Gemini extraction provider (free tier). Get a key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-flash-latest
GEMINI_INPUT_COST_PER_MILLION_TOKENS=0
GEMINI_OUTPUT_COST_PER_MILLION_TOKENS=0

# --- AI pipeline optimizations ---
# Touchless processing: auto-approve invoices that pass every validation rule
# and meet the confidence bars (overall and per-field).
AUTO_APPROVAL_ENABLED=true
AUTO_APPROVAL_MIN_CONFIDENCE=0.92
# Per-field confidence below this routes the invoice to review with the field flagged.
FIELD_CONFIDENCE_REVIEW_THRESHOLD=0.75
# Retrieval-augmented extraction: recent approved same-supplier invoices as few-shot examples.
EXTRACTION_FEW_SHOT_ENABLED=true
EXTRACTION_FEW_SHOT_EXAMPLES=2
# Post-extraction anomaly detection (amount outliers, near-duplicates).
ANOMALY_DETECTION_ENABLED=true
ANOMALY_AMOUNT_ZSCORE_THRESHOLD=3.0
ANOMALY_MIN_HISTORY=3
NEAR_DUPLICATE_SIMILARITY_THRESHOLD=0.97
# LLM-written validation explanations (deterministic templates when disabled).
VALIDATION_EXPLANATIONS_LLM_ENABLED=false
# Model tiering: cheap model first, escalate to OPENAI_EXTRACTION_MODEL on low confidence.
EXTRACTION_TIERING_ENABLED=false
OPENAI_EXTRACTION_TIER1_MODEL=gpt-4.1-mini
EXTRACTION_ESCALATION_CONFIDENCE=0.85
# Reuse stored embeddings for identical source text (skips the provider call).
EMBEDDING_REUSE_ENABLED=true
# Downscale image uploads to this max dimension before extraction; 0 disables.
EXTRACTION_IMAGE_MAX_DIMENSION=2048

# --- Agent layer ---
# AP assistant endpoint (read-only tool-calling agent; keyless fallback without OpenAI).
ASSISTANT_ENABLED=true
ASSISTANT_MAX_TOOL_CALLS=6
# Empty uses OPENAI_EXTRACTION_MODEL for assistant reasoning.
OPENAI_ASSISTANT_MODEL=
# Platform user the stdio MCP server (python -m app.mcp.server) acts as.
MCP_SERVICE_USER_EMAIL=
OBJECT_STORAGE_BUCKET=invoice-platform-local
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_PATH=.local-storage
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
INVOICE_UPLOAD_MAX_BYTES=10485760
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_REQUESTS=20
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INVOICE_FILE_DOWNLOAD_URL_TTL_SECONDS=300
JWT_SECRET=change-me-in-local-only
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
