APP_NAME="FDE Enterprise Invoice Platform"
APP_ENV=staging
APP_DEBUG=false
BACKEND_PORT=8000
FRONTEND_PORT=3000
BACKEND_IMAGE=invoice-platform-backend:staging
FRONTEND_IMAGE=invoice-platform-frontend:staging
VITE_API_BASE_URL=https://replace-with-staging-api.example.com

POSTGRES_DB=invoice_platform_staging
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=replace-with-staging-database-password
DATABASE_URL=postgresql+psycopg://invoice_user:replace-with-staging-database-password@postgres:5432/invoice_platform_staging
REDIS_URL=redis://redis:6379/0
PROCESSING_QUEUE_NAME=invoice_processing_jobs
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_SLEEP_SECONDS=1
PROCESSING_JOB_MAX_ATTEMPTS=3

OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-4.1
OPENAI_INPUT_COST_PER_MILLION_TOKENS=0
OPENAI_OUTPUT_COST_PER_MILLION_TOKENS=0
# Gemini extraction provider (leave key empty to disable this option).
GEMINI_API_KEY=
GEMINI_EXTRACTION_MODEL=gemini-flash-latest
GEMINI_INPUT_COST_PER_MILLION_TOKENS=0
GEMINI_OUTPUT_COST_PER_MILLION_TOKENS=0

OBJECT_STORAGE_BUCKET=invoice-platform-staging
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_PATH=/app/.local-storage
OBJECT_STORAGE_ENDPOINT_URL=
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
INVOICE_UPLOAD_MAX_BYTES=10485760
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_REQUESTS=20
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
CORS_ALLOWED_ORIGINS=https://replace-with-staging-frontend.example.com
INVOICE_FILE_DOWNLOAD_URL_TTL_SECONDS=300
JWT_SECRET=replace-with-strong-staging-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
OTEL_ENABLED=false
OTEL_SERVICE_NAME=invoice-platform-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
RUN_MIGRATIONS_ON_START=false
